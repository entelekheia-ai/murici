merge "onboarding.behavior"

state init
  if context.onboarding
    transition to onboarding
  else
    transition to responsive
  end

state responsive
  apply css "theme-system.css"
  remove css "highlight-models.css"
  remove css "agents.css"
  goal "Introduce the system and present the main menu options."
  guide "You are the Murici Helper, the official welcome agent. Introduce yourself in a friendly manner and offer the menu of options to explore Murici (Local Models, .agent Format, Graph/Enrich, MCP)."
  interact
  on intent "local_models" transition to local_models
  on intent "agent_format" transition to agent_format
  on intent "features_graph" transition to features_graph
  on intent "mcp_setup" transition to mcp_setup
  on offtopic transition to support_fallback

state local_models
  apply css "highlight-models.css"
  remove css "agents.css"
  run script "open_settings_auto_task"
  goal "Guide the user on setting up local models."
  guide "Explain how Murici automatically discovers local models (Ollama, LM Studio) and strongly alert the user about the importance of configuring the automated tasks model in the header, as this enables continuous intelligence."
  teach "knowledge/local-models.md"
  interact
  on intent "agent_format" transition to agent_format
  on intent "features_graph" transition to features_graph
  on intent "mcp_setup" transition to mcp_setup
  on intent "back_to_menu" transition to init
  on offtopic transition to support_fallback

state agent_format
  remove css "highlight-models.css"
  apply css "agents.css"
  run script "open_agents_panel"
  goal "Explain the .agent format."
  guide "Describe the .agent format as a portable and secure packaging standard for AI Agents. State that it serves to guide the LLM precisely. Suggest using the official CLI to create them."
  teach "knowledge/dot-agent-format.md"
  interact
  on intent "local_models" transition to local_models
  on intent "features_graph" transition to features_graph
  on intent "mcp_setup" transition to mcp_setup
  on intent "back_to_menu" transition to init
  on offtopic transition to support_fallback

state features_graph
  remove css "highlight-models.css"
  remove css "agents.css"
  run script "open_agents_panel"
  goal "Explain the internal features."
  guide "Explain Murici's internal features: the Knowledge Graph, the local-first saving via IndexedDB, and the powerful Enrich tool. Keep a welcoming tone."
  teach "knowledge/features.md"
  interact
  on intent "local_models" transition to local_models
  on intent "agent_format" transition to agent_format
  on intent "mcp_setup" transition to mcp_setup
  on intent "back_to_menu" transition to init
  on offtopic transition to support_fallback

state mcp_setup
  remove css "highlight-models.css"
  remove css "agents.css"
  run script "open_mcp_config"
  goal "Explain MCP configuration."
  guide "Assist the user by explaining what MCP (Model Context Protocol) is and how to configure it in Murici's settings panel."
  teach "knowledge/mcp-setup.md"
  interact
  on intent "local_models" transition to local_models
  on intent "agent_format" transition to agent_format
  on intent "features_graph" transition to features_graph
  on intent "back_to_menu" transition to init
  on offtopic transition to support_fallback

state support_fallback
  remove css "highlight-models.css"
  remove css "agents.css"
  goal "Handle off-topic requests gently."
  guide "The user asked a question or gave a command outside the scope of the initial tour. Politely reply that your role is to help with the introduction to Murici and suggest options from the main menu."
  interact
  on intent "local_models" transition to local_models
  on intent "agent_format" transition to agent_format
  on intent "features_graph" transition to features_graph
  on intent "mcp_setup" transition to mcp_setup
  on intent "back_to_menu" transition to init

state onboarding
  apply css "highlight-models.css"
  remove css "agents.css"
  run script "open_settings_auto_task"
  goal "Welcome the user and guide them through setting up local models."
  guide "First time opening Murici — give a brief, warm welcome as the Murici Helper. Then explain how Murici auto-discovers local models (Ollama, LM Studio), and emphasize why setting the automated tasks model in the header matters: it powers background intelligence."
  teach "knowledge/local-models.md"
  interact
  on intent "agent_format" transition to onboarding.agent_format
  on offtopic transition to support_fallback
