{
  "name": "murici",
  "version": "0.0.5",
  "description": "Murici is a lightweight, responsive desktop and web Chat UI designed for running deterministic state-machine agent behaviors.",
  "private": true,
  "author": "Danilo Borges <contato@daniloborg.es>",
  "homepage": "https://entelekheia.ai/",
  "contributors": [
    {
      "name": "Danilo Borges",
      "email": "contato@daniloborg.es"
    }
  ],
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "analyze": "ANALYZE=true npm run build",
    "preview": "next build && next start",
    "type-check": "tsc --noEmit",
    "format:write": "prettier --write \"{app,lib,components,context,types}/**/*.{ts,tsx}\" --cache",
    "format:check": "prettier --check \"{app,lib,components,context,types}**/*.{ts,tsx}\" --cache",
    "test": "jest",
    "test:e2e": "playwright test",
    "build:agents": "node scripts/build-agents.js",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run electron:compile && NODE_ENV=development ELECTRON_ENV=development concurrently -k -n next,electron \"next dev\" \"wait-on http://localhost:3000 && electron electron-dist/main.js\"",
    "electron:build": "ELECTRON_BUILD=1 npm run build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && npm run electron:compile && electron-builder",
    "electron:publish": "npm run electron:build -- --publish always",
    "postinstall": "node scripts/copy-tree-sitter-assets.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.8",
    "@ai-sdk/azure": "^4.0.8",
    "@ai-sdk/google": "^4.0.8",
    "@ai-sdk/mistral": "^4.0.5",
    "@ai-sdk/openai": "^4.0.8",
    "@ai-sdk/react": "^4.0.17",
    "@apidevtools/json-schema-ref-parser": "^11.9.3",
