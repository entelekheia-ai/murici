#!/usr/bin/env sh

. "$(dirname -- "$0")/_/husky.sh"
set -e

# Lint/format only the files staged for this commit — never the whole repo,
# and never `git add .` (that used to silently sweep in unrelated pending
# edits and untracked files sitting elsewhere in the working tree into
# whatever commit happened to run next).
#
# Newline-separated (not -z): a shell command substitution cannot hold NUL
# bytes, so `$(... -z)` would collapse the list into one concatenated blob.
# Matches the convention already used by scripts/ensure-license-headers.sh.
# Assumes staged paths contain no newlines (true for this repo).
staged_ts=$(git diff --cached --name-only --diff-filter=ACM -- "*.ts" "*.tsx")

if [ -n "$staged_ts" ]; then
  echo "$staged_ts" | xargs npx eslint --fix
  echo "$staged_ts" | xargs npx prettier --write
  echo "$staged_ts" | xargs git add
fi

bash scripts/ensure-license-headers.sh
